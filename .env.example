# KYC Client Onboarding Intelligence System - Environment Configuration
# Copy this file to .env and fill in your values

# Required: Anthropic API Key
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-api-key-here

# Optional: Output directory for research results
# OUTPUT_DIR=results

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Optional: Enable verbose output
# VERBOSE=true

# Optional: Override default model (claude-sonnet-4-6)
# MODEL=claude-sonnet-4-6

# Optional: API retry configuration
# MAX_RETRIES=5
# INITIAL_BACKOFF=2
# AGENT_DELAY=30

# Optional: Cost controls
# COST_WARN_USD=5.0
# COST_MAX_USD=15.0
# DAILY_BUDGET_USD=100.0

# Optional: At-rest encryption for result files
# Requires: pip install cryptography
# ENCRYPT_RESULTS=true
# ENCRYPTION_KEY=your-fernet-key-here  # Auto-generated if omitted

# Optional: Trade.gov CSL API key (improves sanctions screening)
# TRADE_GOV_API_KEY=your-key-here

# Optional: Reporting entity for SAR/STR filing pre-fills
# REPORTING_ENTITY_NAME=Your Institution Name
# REPORTING_ENTITY_EIN=00-0000000
# REPORTING_ENTITY_FINTRAC_ID=M00000000
# REPORTING_ENTITY_ADDRESS=123 Main St
# REPORTING_ENTITY_CITY=Toronto
# REPORTING_ENTITY_STATE=ON
# REPORTING_ENTITY_ZIP=M5V 1A1
# REPORTING_ENTITY_COUNTRY=CA
# REPORTING_ENTITY_PHONE=416-555-0000
# REPORTING_ENTITY_TYPE=Depository institution

# Optional: Path to local screening list data
# SCREENING_LIST_PATH=screening_lists

# Testing: Skip network-dependent tests
# SKIP_NETWORK_TESTS=true
